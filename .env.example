# ─────────────────────────────────────────────────────────
# General
# ─────────────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=America/Puerto_Rico

# ─────────────────────────────────────────────────────────
# Domain (used for Traefik labels when enabled)
# ─────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ─────────────────────────────────────────────────────────
# VPN — NordVPN (WireGuard via access token)
# Get token: nordvpn.com → My Account → Access Tokens → Generate New Token
# Gluetun uses the token to fetch the WireGuard private key automatically.
# ─────────────────────────────────────────────────────────
NORDVPN_TOKEN=

# Optional: pin to a specific country (comment out to auto-select best server)
# VPN_SERVER_COUNTRIES=United States
