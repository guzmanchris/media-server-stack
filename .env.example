# ─────────────────────────────────────────────────────────
# General
# ─────────────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=America/Puerto_Rico

# ─────────────────────────────────────────────────────────
# Domain (used for Traefik labels when enabled)
# ─────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ─────────────────────────────────────────────────────────
# VPN — NordVPN (WireGuard)
# Retrieve your private key via the NordVPN API:
#   curl -s -u "token:<YOUR_ACCESS_TOKEN>" https://api.nordvpn.com/v1/users/services/credentials
# Copy the value of "nordlynx_private_key" from the response.
# ─────────────────────────────────────────────────────────
WIREGUARD_PRIVATE_KEY=

# Optional: pin to a specific country (comment out to auto-select best server)
# VPN_SERVER_COUNTRIES=United States
